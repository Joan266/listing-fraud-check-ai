{
  "manifest_version": 3,
  "name": "NoPiques — Analizar anuncio",
  "version": "1.0.1",
  "description": "Extrae el contenido de un anuncio inmobiliario y lo envía a NoPiques para su análisis de fraude.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "optional_permissions": ["languageModel"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "http://localhost:5173/*",
    "http://localhost:8000/*",
    "https://listing-fraud-check-api-999434601012.us-central1.run.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.idealista.com/*",
        "*://*.fotocasa.es/*",
        "*://*.booking.com/*",
        "*://*.airbnb.com/*",
        "*://*.airbnb.es/*",
        "*://*.pisos.com/*",
        "*://*.habitaclia.com/*",
        "*://*.milanuncios.com/*",
        "*://*.wallapop.com/*",
        "*://*.enalquiler.com/*",
        "*://*.yaencontre.com/*",
        "*://*.inmobiliaria.com/*",
        "*://*.vrbo.com/*",
        "*://*.homeaway.com/*",
        "*://*.tripadvisor.com/*",
        "*://*.tripadvisor.es/*",
        "*://*.expedia.com/*",
        "*://*.expedia.es/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
